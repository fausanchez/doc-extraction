# Copy this file to .dev.vars — it's loaded automatically by `wrangler dev`
# NEVER commit .dev.vars

# Must be at least 32 characters (HMAC-SHA256 secret).
# Generate one with: openssl rand -hex 32
JWT_SECRET=please-replace-with-a-long-random-32-byte-secret

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Extraction provider — optional, defaults to `anthropic`.
# Add new ids to `apps/api/src/lib/extraction/registry.ts` to enable them.
# EXTRACTION_PROVIDER=anthropic

# Provider credentials. Only the active provider's keys need to be set.
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI provider — set EXTRACTION_PROVIDER=openai above to enable.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Sentry error tracking — optional. Leave unset for local dev.
# SENTRY_DSN=https://...@sentry.io/...
# ENVIRONMENT=development

# Paddle billing — required for subscription webhook processing.
# Set via: wrangler secret put PADDLE_SECRET_KEY [--env develop|production]
#           wrangler secret put PADDLE_WEBHOOK_SECRET [--env develop|production]
# PADDLE_SECRET_KEY=pdl_skey_...
# PADDLE_WEBHOOK_SECRET=pdl_ntfset_...
