# Copy this file to .dev.vars — it's loaded automatically by `wrangler dev`
# NEVER commit .dev.vars

# Must be at least 32 characters (HMAC-SHA256 secret).
# Generate one with: openssl rand -hex 32
JWT_SECRET=please-replace-with-a-long-random-32-byte-secret

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Extraction provider — optional, defaults to `anthropic`.
# Add new ids to `apps/api/src/lib/extraction/registry.ts` to enable them.
# EXTRACTION_PROVIDER=anthropic

# Provider credentials. Only the active provider's keys need to be set.
ANTHROPIC_API_KEY=sk-ant-...
