{
    "name": "api",
    "type": "module",
    "scripts": {
        "dev": "wrangler dev --port 8787",
        "deploy:develop": "wrangler deploy --env develop",
        "deploy:production": "wrangler deploy --env production",
        "cf-typegen": "wrangler types --env-interface CloudflareBindings",
        "db:migrate": "wrangler d1 migrations apply dvop-io-develop --local",
        "db:migrate:develop": "wrangler d1 migrations apply dvop-io-develop --env develop --remote",
        "db:migrate:production": "wrangler d1 migrations apply dvop-io-production --env production --remote",
        "db:generate": "drizzle-kit generate",
        "db:reset-tokens": "wrangler d1 execute dvop-io-develop --local --file=../../scripts/reset-api-tokens.sql",
        "db:reset-tokens:develop": "wrangler d1 execute dvop-io-develop --env develop --remote --file=../../scripts/reset-api-tokens.sql"
    },
    "dependencies": {
        "@hono/zod-validator": "^0.7.6",
        "@repo/utils": "workspace:*",
        "drizzle-orm": "^0.45.1",
        "hono": "^4.11.9",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": "^25.2.3",
        "drizzle-kit": "^0.31.9",
        "typescript": "^5.9.3",
        "wrangler": "^4.17.0"
    }
}
