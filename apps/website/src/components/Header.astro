---
const APP_URL = import.meta.env.PUBLIC_APP_URL ?? 'http://localhost:5173'
---

<header class="fixed top-4 left-1/2 z-50 w-[min(72rem,calc(100%-2rem))] -translate-x-1/2">
    <div class="glass flex h-14 items-center justify-between rounded-2xl px-3 pl-4 shadow-2xl shadow-black/40">
        <a href="/" class="group flex items-center gap-2.5 font-semibold">
            <span class="relative flex size-8 items-center justify-center rounded-xl bg-gradient-to-br from-brand-500 via-violet-500 to-fuchsia-500 text-sm font-black text-white shadow-lg shadow-brand-600/40">
                <span class="absolute inset-0 rounded-xl bg-white/10 opacity-0 transition-opacity group-hover:opacity-100"></span>
                D
            </span>
            <span class="text-sm tracking-tight text-white">DocExtract</span>
            <span class="hidden rounded-md border border-white/10 bg-white/5 px-1.5 py-0.5 text-[10px] font-medium uppercase tracking-wider text-ink-300 sm:inline-flex">
                Beta
            </span>
        </a>

        <nav class="hidden items-center gap-1 md:flex">
            <a
                href="#features"
                class="rounded-lg px-3 py-1.5 text-sm text-ink-300 transition-colors hover:bg-white/5 hover:text-white"
            >
                Features
            </a>
            <a
                href="#how"
                class="rounded-lg px-3 py-1.5 text-sm text-ink-300 transition-colors hover:bg-white/5 hover:text-white"
            >
                How it works
            </a>
            <a
                href="#stats"
                class="rounded-lg px-3 py-1.5 text-sm text-ink-300 transition-colors hover:bg-white/5 hover:text-white"
            >
                Why us
            </a>
        </nav>

        <div class="flex items-center gap-2">
            <a
                href={APP_URL}
                class="hidden h-9 items-center px-3 text-sm font-medium text-ink-300 transition-colors hover:text-white sm:inline-flex"
            >
                Sign in
            </a>
            <a
                href={APP_URL}
                class="group relative inline-flex h-9 items-center gap-1.5 overflow-hidden rounded-xl bg-gradient-to-r from-brand-500 to-violet-500 px-4 text-sm font-medium text-white shadow-lg shadow-brand-600/30 transition-all hover:shadow-brand-600/60"
            >
                <span class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/20 to-transparent transition-transform duration-700 group-hover:translate-x-full"></span>
                Get started
                <svg class="size-3.5 transition-transform group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 8h10M9 4l4 4-4 4" />
                </svg>
            </a>
        </div>
    </div>
</header>
