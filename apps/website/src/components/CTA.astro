---
const APP_URL = import.meta.env.PUBLIC_APP_URL ?? 'http://localhost:5173'
---

<section class="relative px-6 py-24">
    <div class="mx-auto max-w-5xl">
        <div class="relative overflow-hidden rounded-3xl border border-white/10 p-10 sm:p-16">
            <!-- animated gradient bg -->
            <div aria-hidden="true" class="pointer-events-none absolute inset-0 bg-gradient-to-br from-brand-600 via-violet-600 to-fuchsia-600"></div>
            <div aria-hidden="true" class="pointer-events-none absolute inset-0 bg-grid opacity-20"></div>
            <div aria-hidden="true" class="pointer-events-none absolute -right-24 -top-24 size-72 rounded-full bg-white/20 blur-3xl"></div>
            <div aria-hidden="true" class="pointer-events-none absolute -bottom-24 -left-24 size-72 rounded-full bg-fuchsia-300/30 blur-3xl"></div>

            <div class="relative grid grid-cols-1 items-center gap-8 lg:grid-cols-12">
                <div class="lg:col-span-7">
                    <h2 class="text-balance text-4xl font-bold tracking-tight text-white sm:text-5xl">
                        Stop parsing.
                        <br />
                        <span class="text-white/80">Start shipping.</span>
                    </h2>
                    <p class="mt-4 max-w-xl text-pretty text-base text-white/80 sm:text-lg">
                        Join thousands of teams turning unstructured documents into clean,
                        validated data with a single API call. No credit card required.
                    </p>
                </div>

                <div class="flex flex-col gap-3 sm:flex-row lg:col-span-5 lg:flex-col">
                    <a
                        href={APP_URL}
                        class="group inline-flex h-12 items-center justify-center gap-2 rounded-xl bg-white px-6 text-sm font-semibold text-ink-900 shadow-lg transition-all hover:bg-ink-100 hover:shadow-xl"
                    >
                        Get started — free
                        <svg class="size-4 transition-transform group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 8h10M9 4l4 4-4 4" />
                        </svg>
                    </a>
                    <a
                        href="#how"
                        class="inline-flex h-12 items-center justify-center gap-2 rounded-xl border border-white/20 bg-white/5 px-6 text-sm font-medium text-white backdrop-blur-md transition-colors hover:bg-white/15"
                    >
                        Read the docs
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
