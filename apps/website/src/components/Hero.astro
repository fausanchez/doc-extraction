---
const APP_URL = import.meta.env.PUBLIC_APP_URL ?? 'http://localhost:5173'
---

<section class="flex min-h-svh flex-col items-center justify-center px-6 pt-16 text-center">
    <div class="mx-auto max-w-3xl">
        <span class="inline-flex items-center gap-1.5 rounded-full border border-gray-200 bg-gray-50 px-3 py-1 text-xs font-medium text-gray-600">
            Powered by AI
        </span>

        <h1 class="mt-6 text-5xl font-bold tracking-tight text-gray-900 sm:text-6xl lg:text-7xl">
            Extract data from<br />
            <span class="text-gray-500">any document</span>
        </h1>

        <p class="mt-6 text-lg text-gray-500 max-w-xl mx-auto">
            Upload PDFs and images, define the data structure you need, and get
            structured results in seconds with artificial intelligence.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
            <a
                href={APP_URL}
                class="inline-flex h-11 w-full sm:w-auto items-center justify-center gap-2 rounded-xl bg-gray-900 px-6 text-sm font-medium text-white transition-colors hover:bg-gray-700"
            >
                Get started for free
            </a>
            <a
                href="#how"
                class="inline-flex h-11 w-full sm:w-auto items-center justify-center gap-2 rounded-xl border border-gray-200 px-6 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-50"
            >
                See how it works
            </a>
        </div>
    </div>

    <!-- Mock UI preview -->
    <div class="mt-16 w-full max-w-4xl">
        <div class="rounded-2xl border border-gray-200 bg-gray-50 p-6 shadow-xl shadow-gray-100">
            <div class="flex items-center gap-1.5 mb-4">
                <div class="size-3 rounded-full bg-red-400"></div>
                <div class="size-3 rounded-full bg-yellow-400"></div>
                <div class="size-3 rounded-full bg-green-400"></div>
            </div>
            <div class="grid grid-cols-2 gap-4 text-left">
                <div class="rounded-xl border border-gray-200 bg-white p-4">
                    <p class="text-xs font-medium text-gray-500 mb-3">Uploaded document</p>
                    <div class="flex items-center gap-2 rounded-lg border border-gray-100 bg-gray-50 p-3">
                        <div class="size-8 rounded bg-red-100 flex items-center justify-center text-xs font-bold text-red-600">PDF</div>
                        <div>
                            <p class="text-sm font-medium text-gray-800">invoice-001.pdf</p>
                            <p class="text-xs text-gray-400">245 KB</p>
                        </div>
                    </div>
                </div>
                <div class="rounded-xl border border-gray-200 bg-white p-4">
                    <p class="text-xs font-medium text-gray-500 mb-3">Extracted data</p>
                    <div class="space-y-2">
                        {[['Number', 'INV-2024-0042'], ['Date', '01/15/2024'], ['Total', '$1,250.00'], ['Vendor', 'Acme Corp']].map(([k, v]) => (
                            <div class="flex items-center justify-between text-xs">
                                <span class="text-gray-500">{k}</span>
                                <span class="font-medium text-gray-800">{v}</span>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
