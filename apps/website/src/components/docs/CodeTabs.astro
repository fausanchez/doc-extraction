---
import { Code } from 'astro:components'

interface Props {
    samples: Partial<Record<'curl' | 'javascript' | 'python' | 'go' | 'ruby', string>>
    /** Optional title rendered above the tabs (e.g. "Request"). */
    title?: string
}

const { samples, title } = Astro.props

const langMeta: Record<string, { label: string; lang: string }> = {
    curl: { label: 'curl', lang: 'bash' },
    javascript: { label: 'JavaScript', lang: 'javascript' },
    python: { label: 'Python', lang: 'python' },
    go: { label: 'Go', lang: 'go' },
    ruby: { label: 'Ruby', lang: 'ruby' }
}

// Preserve insertion order of `samples` so authoring order = display order.
const tabs = (Object.keys(samples) as (keyof typeof samples)[]).filter(
    (k) => samples[k] !== undefined
)
---

<div class="not-prose my-4 overflow-hidden rounded-lg border border-gray-200 bg-gray-950" data-code-tabs>
    {
        title && (
            <div class="border-b border-gray-800 bg-gray-900 px-4 py-2 text-[11px] font-medium uppercase tracking-wider text-gray-400">
                {title}
            </div>
        )
    }
    <div
        class="flex items-center gap-1 overflow-x-auto border-b border-gray-800 bg-gray-900 px-2 py-1.5"
        role="tablist"
    >
        {
            tabs.map((tab, i) => (
                <button
                    type="button"
                    role="tab"
                    data-tab={tab}
                    aria-selected={i === 0 ? 'true' : 'false'}
                    class="rounded-md px-2.5 py-1 text-[12px] font-medium text-gray-400 transition-colors hover:text-gray-200 aria-selected:bg-gray-800 aria-selected:text-white"
                >
                    {langMeta[tab].label}
                </button>
            ))
        }
        <button
            type="button"
            data-copy
            class="ml-auto rounded-md px-2 py-1 text-[11px] font-medium text-gray-400 transition-colors hover:bg-gray-800 hover:text-white"
            aria-label="Copy code"
        >
            <span data-copy-text>Copy</span>
        </button>
    </div>
    <div data-panels class="overflow-x-auto p-4 text-[12.5px] leading-relaxed">
        {
            tabs.map((tab, i) => (
                <div
                    data-panel={tab}
                    hidden={i !== 0}
                    class="font-mono text-gray-100"
                >
                    <Code
                        code={samples[tab]!}
                        lang={langMeta[tab].lang as never}
                        theme="github-dark"
                    />
                </div>
            ))
        }
    </div>
</div>

<script>
    type Container = HTMLElement & { dataset: DOMStringMap }

    const STORAGE_KEY = 'docs_code_lang'

    function getPreferred(): string | null {
        try {
            return localStorage.getItem(STORAGE_KEY)
        } catch {
            return null
        }
    }

    function savePreferred(lang: string) {
        try {
            localStorage.setItem(STORAGE_KEY, lang)
        } catch {
            // ignore quota / privacy errors
        }
    }

    function activate(container: Container, lang: string) {
        const tabs = container.querySelectorAll<HTMLButtonElement>('[data-tab]')
        const panels = container.querySelectorAll<HTMLElement>('[data-panel]')
        let matched = false
        tabs.forEach((tab) => {
            const isActive = tab.dataset.tab === lang
            tab.setAttribute('aria-selected', isActive ? 'true' : 'false')
            if (isActive) matched = true
        })
        panels.forEach((panel) => {
            panel.hidden = panel.dataset.panel !== lang
        })
        return matched
    }

    function activeLangIn(container: Container): string | null {
        const visible = container.querySelector<HTMLElement>('[data-panel]:not([hidden])')
        return visible?.dataset.panel ?? null
    }

    document.querySelectorAll<Container>('[data-code-tabs]').forEach((container) => {
        const preferred = getPreferred()
        if (preferred) activate(container, preferred)

        container.querySelectorAll<HTMLButtonElement>('[data-tab]').forEach((tab) => {
            tab.addEventListener('click', () => {
                const lang = tab.dataset.tab
                if (!lang) return
                // Apply to every container on the page so all snippets stay in sync.
                document
                    .querySelectorAll<Container>('[data-code-tabs]')
                    .forEach((c) => activate(c, lang))
                savePreferred(lang)
            })
        })

        const copyBtn = container.querySelector<HTMLButtonElement>('[data-copy]')
        copyBtn?.addEventListener('click', async () => {
            const lang = activeLangIn(container)
            if (!lang) return
            const panel = container.querySelector<HTMLElement>(`[data-panel="${lang}"]`)
            const text = panel?.innerText ?? ''
            try {
                await navigator.clipboard.writeText(text)
                const label = copyBtn.querySelector<HTMLElement>('[data-copy-text]')
                if (label) {
                    const original = label.textContent
                    label.textContent = 'Copied'
                    setTimeout(() => {
                        if (label) label.textContent = original
                    }, 1200)
                }
            } catch {
                // Clipboard may be unavailable in non-secure contexts; fail silently.
            }
        })
    })
</script>
