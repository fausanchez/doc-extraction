---
type Param = {
    name: string
    type: string
    required?: boolean
    default?: string
    description: string
}

interface Props {
    params: Param[]
}

const { params } = Astro.props
---

<div class="not-prose my-4 overflow-hidden rounded-lg border border-gray-200">
    <table class="w-full text-left text-sm">
        <thead class="bg-gray-50 text-[11px] uppercase tracking-wider text-gray-500">
            <tr>
                <th class="px-4 py-2 font-medium">Field</th>
                <th class="px-4 py-2 font-medium">Type</th>
                <th class="px-4 py-2 font-medium">Description</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
            {
                params.map((p) => (
                    <tr class="align-top">
                        <td class="px-4 py-3 font-mono text-[13px] text-gray-900 whitespace-nowrap">
                            {p.name}
                            {p.required ? (
                                <span class="ml-1.5 inline-block rounded-sm bg-red-50 px-1 text-[10px] font-medium text-red-600">
                                    required
                                </span>
                            ) : (
                                <span class="ml-1.5 inline-block text-[10px] text-gray-400">
                                    optional
                                </span>
                            )}
                        </td>
                        <td class="px-4 py-3 font-mono text-[12px] text-gray-600 whitespace-nowrap">
                            {p.type}
                            {p.default !== undefined && (
                                <span class="block text-[11px] text-gray-400">
                                    default: <code style="background:transparent;border:none;padding:0">{p.default}</code>
                                </span>
                            )}
                        </td>
                        <td class="px-4 py-3 text-gray-700">
                            <Fragment set:html={p.description} />
                        </td>
                    </tr>
                ))
            }
        </tbody>
    </table>
</div>
