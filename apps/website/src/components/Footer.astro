---
const links = {
    Product: [
        { label: 'Features', href: '#features' },
        { label: 'How it works', href: '#how' },
        { label: 'Pricing', href: '#' },
        { label: 'Changelog', href: '#' }
    ],
    Developers: [
        { label: 'Documentation', href: '#' },
        { label: 'API reference', href: '#' },
        { label: 'TypeScript SDK', href: '#' },
        { label: 'Status', href: '#' }
    ],
    Company: [
        { label: 'About', href: '#' },
        { label: 'Blog', href: '#' },
        { label: 'Careers', href: '#' },
        { label: 'Contact', href: '#' }
    ],
    Legal: [
        { label: 'Privacy', href: '#' },
        { label: 'Terms', href: '#' },
        { label: 'Security', href: '#' },
        { label: 'DPA', href: '#' }
    ]
}
---

<footer class="relative border-t border-white/10 px-6 pb-10 pt-20">
    <div aria-hidden="true" class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-px bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>

    <div class="mx-auto max-w-6xl">
        <div class="grid grid-cols-2 gap-10 sm:grid-cols-3 lg:grid-cols-6">
            <div class="col-span-2">
                <a href="/" class="flex items-center gap-2.5 font-semibold">
                    <span class="flex size-8 items-center justify-center rounded-xl bg-gradient-to-br from-brand-500 via-violet-500 to-fuchsia-500 text-sm font-black text-white shadow-lg shadow-brand-600/40">
                        D
                    </span>
                    <span class="text-white">dvop.io</span>
                </a>
                <p class="mt-4 max-w-xs text-sm text-ink-400">
                    The fastest way to turn documents into structured data with AI.
                </p>
                <div class="mt-5 flex items-center gap-3">
                    {[
                        { name: 'GitHub', d: 'M12 2a10 10 0 00-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.89 1.53 2.34 1.09 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02a9.5 9.5 0 015 0c1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.93.36.31.68.92.68 1.85V21c0 .27.18.58.69.48A10 10 0 0012 2z' },
                        { name: 'X / Twitter', d: 'M18.244 2H21l-6.52 7.45L22 22h-6.84l-4.79-6.26L4.8 22H2l7-7.99L2 2h6.91l4.34 5.74L18.244 2zm-2.4 18h1.86L7.21 4H5.27l10.574 16z' },
                        { name: 'Discord', d: 'M19.27 5.33A18.07 18.07 0 0014.94 4l-.21.43a16.55 16.55 0 014.04 1.96 12.5 12.5 0 00-13.55 0c.5-.4 2.4-1.55 4.04-1.96L9.06 4a18.07 18.07 0 00-4.33 1.33C2.05 9.93 1.31 14.4 1.68 18.8a18.06 18.06 0 005.55 2.81l1.13-1.55a11.7 11.7 0 01-1.85-.89c.16-.11.31-.22.46-.34a13.04 13.04 0 0011.4 0c.15.12.3.23.46.34a11.7 11.7 0 01-1.85.89l1.13 1.55a18.06 18.06 0 005.55-2.81c.43-5.03-.7-9.46-3.36-13.47zM8.86 15.6c-1.07 0-1.95-.99-1.95-2.21s.86-2.21 1.95-2.21c1.09 0 1.97.99 1.95 2.21 0 1.22-.86 2.21-1.95 2.21zm6.28 0c-1.07 0-1.95-.99-1.95-2.21s.86-2.21 1.95-2.21c1.09 0 1.97.99 1.95 2.21 0 1.22-.86 2.21-1.95 2.21z' }
                    ].map((s) => (
                        <a href="#" aria-label={s.name} class="flex size-9 items-center justify-center rounded-lg border border-white/10 bg-white/5 text-ink-400 transition-colors hover:border-white/20 hover:bg-white/10 hover:text-white">
                            <svg viewBox="0 0 24 24" fill="currentColor" class="size-4">
                                <path d={s.d} />
                            </svg>
                        </a>
                    ))}
                </div>
            </div>

            {Object.entries(links).map(([heading, items]) => (
                <div>
                    <h4 class="text-xs font-semibold uppercase tracking-wider text-ink-300">{heading}</h4>
                    <ul class="mt-4 space-y-2.5">
                        {items.map((item) => (
                            <li>
                                <a href={item.href} class="text-sm text-ink-400 transition-colors hover:text-white">
                                    {item.label}
                                </a>
                            </li>
                        ))}
                    </ul>
                </div>
            ))}
        </div>

        <div class="mt-16 flex flex-col items-center justify-between gap-4 border-t border-white/10 pt-8 sm:flex-row">
            <p class="text-xs text-ink-500">© {new Date().getFullYear()} dvop.io. All rights reserved.</p>
            <div class="flex items-center gap-2 text-xs text-ink-500">
                <span class="flex items-center gap-1.5">
                    <span class="relative flex size-1.5">
                        <span class="absolute inline-flex size-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
                        <span class="relative inline-flex size-1.5 rounded-full bg-emerald-400"></span>
                    </span>
                    All systems operational
                </span>
                <span class="text-ink-700">·</span>
                <span>v1.0.0</span>
            </div>
        </div>
    </div>
</footer>
