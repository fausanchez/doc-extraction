---
const steps = [
    {
        number: '01',
        title: 'Upload your document',
        description: 'Drag a PDF or image — or POST it to our API. Files up to 10 MB, multi-page supported, OCR built-in.',
        code: `curl -X POST https://api.dvop.io/v1/extract \\
  -F "file=@invoice.pdf" \\
  -F "schema_id=inv_2024"`,
        accent: 'from-brand-500 to-violet-500'
    },
    {
        number: '02',
        title: 'Define a schema',
        description: 'Pick a template or describe the JSON shape you want. The AI follows your contract — strict types, nested objects and enums all work.',
        code: `{
  "invoice_number": "string",
  "total": "number",
  "line_items": [{
    "sku": "string",
    "qty": "number"
  }]
}`,
        accent: 'from-fuchsia-500 to-pink-500'
    },
    {
        number: '03',
        title: 'Get production-ready JSON',
        description: 'Receive validated, typed data in seconds. Stream it, store it, hit a webhook — it is ready to flow into your stack.',
        code: `{
  "invoice_number": "INV-0042",
  "total": 1250.00,
  "line_items": [
    { "sku": "ACM-1", "qty": 3 },
    { "sku": "ACM-2", "qty": 1 }
  ]
}`,
        accent: 'from-emerald-500 to-teal-500'
    }
]
---

<section id="how" class="relative px-6 py-32">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10 mask-fade-radial bg-grid opacity-30"></div>

    <div class="mx-auto max-w-6xl">
        <div class="mx-auto max-w-2xl text-center">
            <span class="inline-flex items-center gap-1.5 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium text-ink-300">
                <span class="size-1.5 rounded-full bg-fuchsia-400"></span>
                How it works
            </span>
            <h2 class="mt-5 text-balance text-4xl font-bold tracking-tight text-white sm:text-5xl">
                From file to <span class="text-gradient-brand">JSON</span> in three steps
            </h2>
            <p class="mt-4 text-pretty text-lg text-ink-400">
                A workflow simple enough for prototypes, robust enough for production.
            </p>
        </div>

        <div class="relative mt-20">
            <!-- vertical connector line -->
            <div aria-hidden="true" class="absolute left-6 top-6 bottom-6 hidden w-px bg-gradient-to-b from-brand-500/60 via-fuchsia-500/60 to-emerald-500/60 md:block"></div>

            <ol class="space-y-8">
                {steps.map((step, i) => (
                    <li class="relative grid grid-cols-1 gap-6 md:grid-cols-12 md:items-center">
                        <!-- index marker -->
                        <div class="md:col-span-1">
                            <div class={`relative z-10 inline-flex size-12 items-center justify-center rounded-2xl bg-gradient-to-br ${step.accent} font-mono text-sm font-bold text-white shadow-xl ring-1 ring-white/20`}>
                                {step.number}
                            </div>
                        </div>

                        <!-- description -->
                        <div class="md:col-span-5">
                            <h3 class="text-2xl font-semibold tracking-tight text-white">{step.title}</h3>
                            <p class="mt-2 text-pretty text-base text-ink-400">{step.description}</p>
                        </div>

                        <!-- code preview -->
                        <div class="md:col-span-6">
                            <div class="overflow-hidden rounded-xl border border-white/10 bg-ink-900/80 shadow-xl shadow-black/40 backdrop-blur">
                                <div class="flex items-center justify-between border-b border-white/10 bg-ink-900/60 px-3 py-2">
                                    <div class="flex items-center gap-1.5">
                                        <span class="size-2 rounded-full bg-red-500/70"></span>
                                        <span class="size-2 rounded-full bg-yellow-500/70"></span>
                                        <span class="size-2 rounded-full bg-emerald-500/70"></span>
                                    </div>
                                    <span class="font-mono text-[10px] uppercase tracking-wider text-ink-500">{i === 0 ? 'shell' : 'json'}</span>
                                </div>
                                <pre class="overflow-x-auto p-4 font-mono text-[12px] leading-relaxed text-ink-200"><code>{step.code}</code></pre>
                            </div>
                        </div>
                    </li>
                ))}
            </ol>
        </div>
    </div>
</section>
