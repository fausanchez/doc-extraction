---
const features = [
    {
        title: 'Multi-format ingestion',
        description: 'PDFs, JPG, PNG, WebP and scanned documents. Up to 10 MB per file with automatic OCR fallback.',
        accent: 'from-brand-500/20 to-violet-500/20',
        ring: 'ring-brand-500/30',
        icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="size-6"><path d="M14 3H7a2 2 0 00-2 2v14a2 2 0 002 2h10a2 2 0 002-2V8z"/><path d="M14 3v5h5M9 13h6M9 17h4"/></svg>`,
        badge: 'PDF · JPG · PNG · WebP'
    },
    {
        title: 'Custom JSON schemas',
        description: 'Define exactly the shape of the data you need. Nested objects, arrays, enums and strict types — all validated.',
        accent: 'from-fuchsia-500/20 to-pink-500/20',
        ring: 'ring-fuchsia-500/30',
        icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="size-6"><path d="M8 4H6a2 2 0 00-2 2v3a2 2 0 01-2 2 2 2 0 012 2v3a2 2 0 002 2h2"/><path d="M16 4h2a2 2 0 012 2v3a2 2 0 002 2 2 2 0 00-2 2v3a2 2 0 01-2 2h-2"/></svg>`,
        badge: 'Zod · TypeScript'
    },
    {
        title: 'Sub-second latency',
        description: 'Streaming results with edge inference. Process 100 documents in parallel, see results as they finish.',
        accent: 'from-amber-500/20 to-orange-500/20',
        ring: 'ring-amber-500/30',
        icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="size-6"><path d="M13 2L4 14h7l-1 8 9-12h-7l1-8z"/></svg>`,
        badge: '~1.4s avg · streaming'
    },
    {
        title: 'Enterprise-grade auth',
        description: 'OAuth with Google and GitHub. SSO ready. Granular permissions and audit logs for every extraction.',
        accent: 'from-emerald-500/20 to-teal-500/20',
        ring: 'ring-emerald-500/30',
        icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="size-6"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>`,
        badge: 'SOC 2 ready'
    },
    {
        title: 'Edge-native storage',
        description: 'Documents stored on Cloudflare R2 with end-to-end encryption. Zero egress fees, infinite scale.',
        accent: 'from-cyan-500/20 to-sky-500/20',
        ring: 'ring-cyan-500/30',
        icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="size-6"><path d="M18 10h-1.26A8 8 0 109 20h9a5 5 0 000-10z"/></svg>`,
        badge: 'Cloudflare R2'
    },
    {
        title: 'API-first by design',
        description: 'REST and webhooks out of the box. TypeScript SDK, OpenAPI spec and idempotency keys for every call.',
        accent: 'from-violet-500/20 to-indigo-500/20',
        ring: 'ring-violet-500/30',
        icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="size-6"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
        badge: 'REST · Webhooks · SDK'
    }
]
---

<section id="features" class="relative px-6 py-32">
    <div class="mx-auto max-w-6xl">
        <div class="mx-auto max-w-2xl text-center">
            <span class="inline-flex items-center gap-1.5 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium text-ink-300">
                <span class="size-1.5 rounded-full bg-brand-400"></span>
                Features
            </span>
            <h2 class="mt-5 text-balance text-4xl font-bold tracking-tight text-white sm:text-5xl">
                Built for teams that ship
                <span class="text-gradient-brand">fast</span>
            </h2>
            <p class="mt-4 text-pretty text-lg text-ink-400">
                Everything you need to put document understanding into production —
                without babysitting models, brittle regexes or manual cleanup.
            </p>
        </div>

        <div class="mt-16 grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
            {features.map((f, i) => (
                <article
                    class="group relative overflow-hidden rounded-2xl border border-white/10 bg-gradient-to-b from-white/[0.04] to-white/[0.01] p-6 transition-all duration-300 hover:border-white/20 hover:from-white/[0.08]"
                    style={`animation-delay: ${i * 80}ms`}
                >
                    <div aria-hidden="true" class={`pointer-events-none absolute -right-12 -top-12 size-40 rounded-full bg-gradient-to-br ${f.accent} opacity-0 blur-2xl transition-opacity duration-500 group-hover:opacity-100`}></div>

                    <div class={`relative inline-flex size-12 items-center justify-center rounded-xl bg-gradient-to-br ${f.accent} text-white ring-1 ${f.ring}`}>
                        <Fragment set:html={f.icon} />
                    </div>

                    <h3 class="mt-5 text-lg font-semibold text-white">{f.title}</h3>
                    <p class="mt-2 text-sm leading-relaxed text-ink-400">{f.description}</p>

                    <div class="mt-5 inline-flex items-center gap-1.5 rounded-md border border-white/10 bg-ink-950/40 px-2 py-1 font-mono text-[10px] uppercase tracking-wider text-ink-400">
                        {f.badge}
                    </div>
                </article>
            ))}
        </div>
    </div>
</section>
