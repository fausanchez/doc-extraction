---
const features = [
    {
        icon: '📄',
        title: 'Multiple formats',
        description: 'Supports PDFs, JPG, PNG and WebP images. Up to 10MB per file.'
    },
    {
        icon: '🧩',
        title: 'Custom templates',
        description: 'Define exactly which fields you want to extract and their data type.'
    },
    {
        icon: '⚡',
        title: 'Extraction in seconds',
        description: 'We process your document with AI and return the structured data instantly.'
    },
    {
        icon: '🔐',
        title: 'Google & GitHub login',
        description: 'Secure access without needing to create a new password.'
    },
    {
        icon: '☁️',
        title: 'Cloud storage',
        description: 'Your documents are stored securely on Cloudflare R2.'
    },
    {
        icon: '📊',
        title: 'JSON results',
        description: 'Export data in JSON format ready to use in any system.'
    }
]
---

<section id="features" class="py-24 px-6 bg-gray-50">
    <div class="mx-auto max-w-6xl">
        <div class="text-center mb-16">
            <h2 class="text-3xl font-bold text-gray-900 sm:text-4xl">Everything you need</h2>
            <p class="mt-4 text-gray-500 max-w-xl mx-auto">
                A complete platform to extract structured data from documents with AI.
            </p>
        </div>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {features.map((f) => (
                <div class="rounded-2xl border border-gray-200 bg-white p-6 transition-shadow hover:shadow-md">
                    <div class="text-3xl mb-4">{f.icon}</div>
                    <h3 class="font-semibold text-gray-900 mb-2">{f.title}</h3>
                    <p class="text-sm text-gray-500 leading-relaxed">{f.description}</p>
                </div>
            ))}
        </div>
    </div>
</section>
