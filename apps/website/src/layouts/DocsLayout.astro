---
import Layout from './Layout.astro'
import Sidebar from '../components/docs/Sidebar.astro'
import DocsHeader from '../components/docs/DocsHeader.astro'
import TokenInjector from '../components/docs/TokenInjector.astro'

interface Props {
    title: string
    description?: string
    section: string
    page: string
}

const { title, description, section, page } = Astro.props
---

<Layout
    title={`${title} — dvop.io API`}
    description={description ?? `${title} — dvop.io API reference and examples.`}
>
    {/*
      Layout.astro ships a dark mesh/grid theme for the marketing surface;
      docs render on a clean light surface. The opaque white wrapper hides
      the dark body + fixed mesh background underneath.
    */}
    <div class="relative z-0 min-h-svh bg-white text-gray-900">
        <DocsHeader activeSection={section} activePage={page} />

        <div class="mx-auto flex w-full max-w-7xl gap-10 px-4 py-10 lg:px-6">
            <aside class="hidden w-60 shrink-0 lg:block">
                <div class="sticky top-20">
                    <Sidebar activeSection={section} activePage={page} />
                </div>
            </aside>

            <main class="min-w-0 flex-1">
                <TokenInjector />
                <article class="docs-prose">
                    <slot />
                </article>
                <slot name="footer" />
            </main>
        </div>
    </div>
</Layout>

<style is:global>
    /* Lightweight prose rules for docs pages — close to typography defaults
       but pinned to the marketing site's neutral palette so docs feel like
       part of the same product. */
    .docs-prose {
        max-width: 48rem;
        font-size: 15px;
        line-height: 1.65;
        color: #1f2937;
    }
    .docs-prose h1 {
        font-size: 2rem;
        line-height: 1.15;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: #0f172a;
        margin-bottom: 0.5rem;
    }
    .docs-prose h1 + p.lede {
        font-size: 1.0625rem;
        color: #6b7280;
        margin-top: 0;
        margin-bottom: 2rem;
    }
    .docs-prose h2 {
        font-size: 1.375rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: #0f172a;
        margin-top: 2.5rem;
        margin-bottom: 0.75rem;
        scroll-margin-top: 6rem;
    }
    .docs-prose h3 {
        font-size: 1.0625rem;
        font-weight: 600;
        color: #0f172a;
        margin-top: 1.75rem;
        margin-bottom: 0.5rem;
        scroll-margin-top: 6rem;
    }
    .docs-prose p,
    .docs-prose li {
        color: #374151;
        margin-bottom: 0.85rem;
    }
    .docs-prose a {
        color: #2563eb;
        text-decoration: underline;
        text-underline-offset: 2px;
    }
    .docs-prose a:hover {
        color: #1d4ed8;
    }
    .docs-prose ul {
        padding-left: 1.25rem;
        list-style: disc;
    }
    .docs-prose ul li::marker {
        color: #9ca3af;
    }
    .docs-prose code {
        background: #f3f4f6;
        border: 1px solid #e5e7eb;
        border-radius: 4px;
        padding: 1px 5px;
        font-size: 0.85em;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        color: #111827;
    }
    .docs-prose pre {
        margin: 0;
    }
    .docs-prose pre code {
        background: transparent;
        border: none;
        padding: 0;
        font-size: 13px;
        color: inherit;
    }
    .docs-prose hr {
        border: 0;
        border-top: 1px solid #e5e7eb;
        margin: 2.5rem 0;
    }
    .docs-prose strong {
        color: #0f172a;
    }
</style>
