{
    "name": "app",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "build:develop": "tsc -b && vite build --mode develop",
        "build:production": "tsc -b && vite build --mode production",
        "lint": "eslint .",
        "preview": "vite preview",
        "deploy:develop": "pnpm build:develop && wrangler pages deploy dist --project-name dvop-io-app --branch develop",
        "deploy:production": "pnpm build:production && wrangler pages deploy dist --project-name dvop-io-app"
    },
    "dependencies": {
        "@repo/utils": "workspace:*",
        "@tailwindcss/vite": "^4.1.18",
        "jotai": "^2.17.1",
        "ky": "^1.14.3",
        "lucide-react": "^0.564.0",
        "motion": "^12.34.2",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-router": "^7.13.0",
        "sonner": "^2.0.7",
        "tailwindcss": "^4.1.18",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@repo/eslint-config": "workspace:*",
        "@repo/typescript-config": "workspace:*",
        "@repo/ui": "workspace:*",
        "@types/node": "^24.10.13",
        "@types/react": "19.2.2",
        "@types/react-dom": "19.2.2",
        "@vitejs/plugin-react": "^5.1.1",
        "eslint": "^9.39.1",
        "eslint-config-prettier": "^10.1.1",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.24",
        "globals": "^16.5.0",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.48.0",
        "vite": "^7.3.1",
        "wrangler": "^4.0.0"
    }
}
