# Copy this file to .env.develop or .env.production and fill in the values

# URL of the deployed API worker
VITE_API_URL=https://api.doc-extraction.com

# Google OAuth client ID (public, safe to expose)
VITE_GOOGLE_CLIENT_ID=

# GitHub OAuth client ID (public, safe to expose)
VITE_GITHUB_CLIENT_ID=

# Sentry DSN for frontend error tracking — optional. Leave unset for local dev.
# VITE_SENTRY_DSN=https://...@sentry.io/...

# Paddle billing — required for checkout buttons to appear.
# VITE_PADDLE_CLIENT_TOKEN=live_...   (client-side token from Paddle dashboard)
# VITE_PADDLE_ENV=production          (or 'sandbox' for testing)
